---
/**
 * The three headline differentiator cards, shared by the homepage comparison
 * section (Comparison.astro) and the /compare hub so the card markup lives in
 * one place. `as` sets the heading level for correct document outline: h3 under
 * the landing section's h2, h2 directly under the /compare page h1.
 */
import { comparison } from "../config/landing";

interface Props {
  as?: "h2" | "h3";
}

const { as: Heading = "h3" } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-3">
  {
    comparison.pillars.map((p, i) => (
      <div class="border-2 border-border bg-surface-1 p-6">
        <span class="font-mono text-sm font-bold text-accent">
          {String(i + 1).padStart(2, "0")}
        </span>
        <Heading class="mt-3 text-xl font-semibold">{p.title}</Heading>
        <p class="mt-3 text-pretty leading-relaxed text-fg-muted">{p.body}</p>
      </div>
    ))
  }
</div>
