---
import { pricing } from "../config/landing";
---

{
  pricing.enabled && (
    <section id="pricing" class="scroll-mt-20 border-t border-border/60 py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
            {pricing.heading}
          </h2>
          <p class="mt-4 text-lg text-fg-muted">{pricing.subhead}</p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-3">
          {pricing.tiers.map((tier) => (
            <div
              class={`flex flex-col p-8 ${
                tier.featured
                  ? "border-2 border-accent bg-surface-1"
                  : "border border-border bg-surface-1"
              }`}
            >
              <h3 class="text-lg font-semibold">{tier.name}</h3>
              <div class="mt-4 flex items-baseline gap-1">
                <span class="text-4xl font-bold">{tier.price}</span>
                {tier.cadence && (
                  <span class="text-fg-muted">{tier.cadence}</span>
                )}
              </div>
              <p class="mt-3 text-sm text-fg-muted">{tier.description}</p>
              <ul class="mt-6 space-y-3 text-sm">
                {tier.features.map((f) => (
                  <li class="flex items-start gap-2">
                    <svg
                      class="mt-0.5 size-4 shrink-0 text-accent"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 6L9 17l-5-5" />
                    </svg>
                    <span class="text-fg-muted">{f}</span>
                  </li>
                ))}
              </ul>
              <a
                href={tier.href}
                class={`mt-8 px-5 py-2.5 text-center font-semibold transition ${
                  tier.featured
                    ? "bg-accent text-accent-fg hover:bg-accent-strong"
                    : "border-2 border-border text-fg hover:border-accent hover:text-accent"
                }`}
              >
                {tier.cta}
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
