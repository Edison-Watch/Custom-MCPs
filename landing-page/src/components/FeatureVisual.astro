---
/*
 * Bespoke Edison-brand wireframe diagram for each feature, selected by `name`
 * (the `visual` key on each feature in config). Rendered both in the sticky
 * desktop panel and inline on mobile (Features.astro). Decorative.
 */
interface Props {
  name: string;
}
const { name } = Astro.props;
---

{
  /* Three transports, zero duplication */
  name === "transports" && (
    <div class="flex h-full flex-col justify-center gap-6 p-6" aria-hidden="true">
      <div class="grid grid-cols-3 gap-3 font-mono text-xs">
        {["CLI", "MCP", "HTTP"].map((t) => (
          <div class="border border-accent/50 bg-bg px-2 py-3 text-center text-accent">
            {t}
          </div>
        ))}
      </div>
      <div class="flex justify-center">
        <svg class="size-7 text-fg-subtle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 4v6M12 4v6M19 4v6M5 10h14M12 10v6M12 16l-3-3M12 16l3-3" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </div>
      <div class="border-2 border-accent bg-bg p-4">
        <p class="font-mono text-[11px] text-fg-subtle">@service</p>
        <p class="mt-1 font-mono text-sm text-fg">gmail_curate_inbox()</p>
        <p class="mt-2 text-xs text-fg-muted">one shared service registry</p>
      </div>
    </div>
  )
}

{
  /* Headless or interactive */
  name === "interactive" && (
    <div class="flex h-full flex-col justify-center p-6" aria-hidden="true">
      <div class="border-2 border-accent bg-bg">
        <div class="flex items-center justify-between border-b border-border px-3 py-2">
          <span class="text-xs font-semibold text-fg">Curated Inbox</span>
          <span class="font-mono text-[10px] uppercase tracking-wider text-accent">ui://mymcp/gmail_inbox</span>
        </div>
        <div class="inline-flex items-center gap-1.5 border-b border-border px-3 py-2 font-mono text-[11px] text-fg-muted">
          <svg class="size-3 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 8l4 4-4 4m6 0h6" stroke-linecap="round" stroke-linejoin="round" /></svg>
          gmail_curate_inbox <span class="text-accent">✓</span>
        </div>
        <ul class="divide-y divide-border">
          {[
            { s: "Re: Q3 contract", high: true },
            { s: "Invoice #8472 is ready", high: false },
          ].map((r) => (
            <li class="flex items-center gap-2.5 px-3 py-2.5">
              <span class={`size-2 shrink-0 ${r.high ? "bg-accent" : "border border-fg-subtle"}`} />
              <span class="truncate text-[13px] text-fg">{r.s}</span>
            </li>
          ))}
        </ul>
        <div class="flex items-center gap-2 border-t border-border px-3 py-2">
          <span class="bg-accent px-2.5 py-1 text-[11px] font-semibold text-accent-fg">Draft replies</span>
          <span class="font-mono text-[10px] text-fg-subtle">postMessage → host</span>
        </div>
      </div>
    </div>
  )
}
