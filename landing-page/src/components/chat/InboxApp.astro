---
/*
 * The MCP UI App (gmail_inbox curated-inbox) rendered inside the chat mocks.
 *
 * A faithful, static reproduction of the REAL App at
 * `mcp_server/apps/gmail_inbox/src/Inbox.tsx` - NOT an Edison-branded card.
 * A real MCP App is a sandboxed iframe that ships its own neutral UI so it
 * renders identically inside any host (Claude / ChatGPT / Goose / VS Code),
 * which is why it does NOT carry the marketing site's Hackbox brand. We mirror
 * its real look: a light, Gmail-flavored client (white surface, #202124 text,
 * #e8f0fe selection, importance-score + label + draft chips, and the signature
 * cyan "AI reply" gradient button).
 *
 * The real App is a two-pane (list + reader) layout, but two panes get squished
 * inside a chat-message column. So instead of cramming both, we animate the
 * SINGLE-PANE flow the app uses on a narrow panel, on a CSS loop (no JS):
 *
 *   1. curated list - a pointer taps the top thread.
 *   2. reader       - full thread + reply buttons; the pointer taps the cyan
 *                     "AI reply" button. Per Inbox.tsx:296-309, that click does
 *                     NOT open an in-app composer - it (a) shows a green
 *                     "Researching context & drafting reply…" status pill
 *                     (setStatus, Inbox.tsx:301), and (b) calls
 *                     mcpApp.sendMessage({role:"user", …}) which posts a NEW
 *                     user turn into the HOST chat. The surrounding shell
 *                     (see *Shell.astro via ConvoScroll) scrolls down to reveal
 *                     that summoned turn + the agent's gmail_reply_to_thread,
 *                     and then the served composer UI (ComposerApp.astro) that
 *                     the tool renders as a fresh card in the new turn. This
 *                     inbox card itself stays on the reader - it is NOT mutated;
 *                     the editable draft is a new embedded UI below the reply.
 *
 * Reduced-motion users get the static curated list. Decorative; sample content.
 */
const threads = [
  {
    initial: "D",
    avatar: "#7b6cf6",
    subject: "Re: Q3 contract - countersignature",
    from: "Dana Whitfield",
    snippet: "Looks good on our end. Just need your signature on page 4 before EOD.",
    score: "0.86",
    foot: "2 days ago",
    hasDraft: true,
    unread: true,
    reason: "awaiting your reply",
  },
  {
    initial: "P",
    avatar: "#1a73e8",
    subject: "Design review for v2 dashboard",
    from: "Priya Nair",
    snippet: "Pushing our review an hour, calendar invite updated.",
    score: "0.61",
    foot: "5 hours ago",
    hasDraft: false,
    unread: true,
    reason: "mentions you",
  },
  {
    initial: "S",
    avatar: "#188038",
    subject: "Your invoice is ready",
    from: "billing@stripe.com",
    snippet: "Your monthly statement is attached. Total due $1,204.00.",
    score: "0.42",
    foot: "1 day ago",
    hasDraft: false,
    unread: false,
    reason: "has attachment",
  },
];
---

<div
  class="inbox-app relative h-[316px] w-full max-w-[460px] overflow-hidden rounded-lg border border-black/10 bg-white text-[#202124] shadow-sm"
  style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif"
>
  <!-- SCREEN 1 - curated list -->
  <div class="screen screen-list absolute inset-0 flex flex-col">
    <div class="flex items-center justify-between border-b border-[#eee] px-3.5 py-2.5">
      <strong class="text-[13px] font-semibold">Curated inbox</strong>
      <div class="flex items-center gap-1">
        <span class="grid h-6 min-w-6 place-items-center rounded-full bg-[#e8f0fe] px-1.5 text-[11px] font-semibold text-[#1a73e8]">123</span>
        <span class="grid size-6 place-items-center rounded-full text-[#5f6368]">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"></path><path d="M21 3v5h-5"></path></svg>
        </span>
      </div>
    </div>

    <ul class="flex-1">
      {
        threads.map((t, i) => (
          <li class={`relative border-b border-[#f0f0f0] px-3.5 py-2.5 ${i === 0 ? "row-target" : ""}`}>
            <div class="flex items-start gap-2.5">
              <span
                class="grid size-7 shrink-0 place-items-center rounded-full text-[11px] font-semibold text-white"
                style={`background:${t.avatar}`}
              >
                {t.initial}
              </span>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class={`flex-1 truncate text-[13px] ${t.unread ? "font-bold" : "font-medium"}`}>
                    {t.subject}
                  </span>
                  <span class="shrink-0 rounded-[10px] bg-[#f1f3f4] px-1.5 py-0.5 text-[11px] text-[#444]">
                    {t.score}
                  </span>
                </div>
                <div class="mt-1 flex flex-wrap items-center gap-1.5">
                  {t.hasDraft && (
                    <span class="inline-flex items-center gap-0.5 rounded-lg bg-[#fce8e6] px-1.5 py-0.5 text-[10px] font-semibold text-[#c5221f]">
                      Draft <span class="opacity-60">×</span>
                    </span>
                  )}
                  {t.unread && (
                    <span class="rounded-lg bg-[#e8f0fe] px-1.5 py-0.5 text-[10px] font-medium text-[#1967d2]">Unread</span>
                  )}
                  <span class="rounded-lg bg-[#f1f3f4] px-1.5 py-0.5 text-[10px] font-medium text-[#5f6368]">{t.reason}</span>
                </div>
                <div class="mt-1 truncate text-[12px] text-[#555]">{t.from}</div>
                <div class="truncate text-[12px] text-[#888]">{t.snippet}</div>
              </div>
              <span class="shrink-0 self-center text-[11px] text-[#999]">{t.foot}</span>
            </div>
            {i === 0 && <span class="tap-ripple" aria-hidden="true" />}
          </li>
        ))
      }
    </ul>
  </div>

  <!-- SCREEN 2 - reader -->
  <div class="screen screen-reader absolute inset-0 flex flex-col">
    <div class="flex items-center gap-1.5 border-b border-[#eee] px-3 py-2.5 text-[12px] text-[#5f6368]">
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"></path></svg>
      Inbox
    </div>
    <div class="flex min-h-0 flex-1 flex-col p-3.5">
      <strong class="text-[15px] font-semibold leading-snug">Re: Q3 contract - countersignature</strong>
      <div class="mt-1.5 flex items-center gap-2 text-[12px] text-[#5f6368]">
        <span class="grid size-6 shrink-0 place-items-center rounded-full bg-[#7b6cf6] text-[10px] font-semibold text-white">D</span>
        Dana Whitfield &lt;dana@acme.legal&gt;
      </div>
      <p class="mt-3 text-[13px] leading-relaxed text-[#3c4043]">
        Looks good on our end. Just need your signature on page 4 before EOD -
        once that's in we can countersign and get this filed today.
      </p>

      <div class="mt-auto flex gap-2 pt-3">
        <button type="button" class="fast-reply-btn" tabindex="-1">
          <svg class="fast-sparkle size-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.9 5.6L19.5 9l-5.6 1.9L12 16.5l-1.9-5.6L4.5 9l5.6-1.4z"></path></svg>
          Reply
        </button>
        <button type="button" class="ai-reply-btn" tabindex="-1">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l1.9 5.6L19.5 9l-5.6 1.9L12 16.5l-1.9-5.6L4.5 9l5.6-1.4z"></path></svg>
          AI reply
          <span class="ai-ripple" aria-hidden="true"></span>
        </button>
      </div>
    </div>

    <!-- green agent status pill: appears the instant "AI reply" is tapped and the
         host-chat message is dispatched (real setStatus, Inbox.tsx:301) -->
    <div class="status-pill absolute inset-x-3.5 bottom-3 flex items-center gap-2 rounded-md border border-[#b6e0c2] bg-[#e6f4ea] px-2.5 py-1.5 text-[12px] font-medium text-[#137333]" aria-hidden="true">
      <span class="status-dot size-1.5 shrink-0 rounded-full bg-[#137333]"></span>
      Researching context &amp; drafting reply…
    </div>
  </div>

  <!-- faux pointer: taps the top thread (~12%), then the cyan "AI reply" (~34%) -->
  <span class="pointer-cursor" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="#202124" stroke="#fff" stroke-width="1.2"><path d="M5 3l14 8-6 1.5L10 18z"></path></svg>
  </span>
</div>

<style>
  /* ---- list -> reader -> tap "AI reply", one shared 15s loop (no JS). The
     shell's ConvoScroll uses the SAME 15s loop: it scrolls down at ~42% to
     reveal the summoned host-chat turn, then keeps scrolling to the served
     composer UI (ComposerApp). This inbox card itself just holds on the reader
     + status pill from ~16%–90% - it is not mutated by the reply. */
  .screen {
    animation-duration: 15s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .screen-list { animation-name: list-cycle; }
  .screen-reader { animation-name: reader-cycle; }

  @keyframes list-cycle {
    0%, 11% { opacity: 1; transform: translateX(0); }
    15%, 90% { opacity: 0; transform: translateX(-10px); }
    94%, 100% { opacity: 1; transform: translateX(0); }
  }
  @keyframes reader-cycle {
    0%, 13% { opacity: 0; transform: translateX(10px); }
    16%, 90% { opacity: 1; transform: translateX(0); }
    94%, 100% { opacity: 0; transform: translateX(10px); }
  }

  /* faux pointer: top thread (~12%) -> AI reply (~34%), then it fades (the
     action has moved to the host chat) */
  .pointer-cursor {
    position: absolute;
    left: 30%;
    top: 230px;
    width: 20px;
    height: 20px;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.3));
    animation: cursor-path 15s ease-in-out infinite;
  }
  .pointer-cursor svg { width: 100%; height: 100%; }
  @keyframes cursor-path {
    0% { left: 30%; top: 230px; opacity: 0; transform: scale(1); }
    3% { opacity: 1; }
    9% { left: 24%; top: 62px; transform: scale(1); }
    12% { left: 24%; top: 62px; transform: scale(0.8); }
    15% { left: 24%; top: 62px; transform: scale(1); }
    28%, 32% { left: 60%; top: 266px; transform: scale(1); }
    34% { left: 60%; top: 266px; transform: scale(0.8); }
    37% { left: 60%; top: 266px; transform: scale(1); }
    38% { opacity: 1; }
    42%, 100% { left: 60%; top: 266px; opacity: 0; transform: scale(1); }
  }

  /* tap ripple on the top thread at the first click (~12%) */
  .tap-ripple {
    position: absolute;
    top: 16px;
    left: 28%;
    width: 28px;
    height: 28px;
    border-radius: 9999px;
    background: rgba(26, 115, 232, 0.35);
    transform: translate(-50%, -50%) scale(0.4);
    opacity: 0;
    animation: tap-row 15s ease-in-out infinite;
  }
  @keyframes tap-row {
    0%, 9% { opacity: 0; transform: translate(-50%, -50%) scale(0.4); }
    12% { opacity: 0.6; transform: translate(-50%, -50%) scale(0.6); }
    16% { opacity: 0; transform: translate(-50%, -50%) scale(1.7); }
    100% { opacity: 0; }
  }
  /* top row tints as it's "selected" */
  .row-target { animation: row-select 15s ease-in-out infinite; }
  @keyframes row-select {
    0%, 9% { background: transparent; }
    12%, 16% { background: #e8f0fe; }
    20%, 100% { background: transparent; }
  }

  /* ripple on the AI reply button (~34%) */
  .ai-ripple {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 36px;
    height: 36px;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.55);
    transform: translate(-50%, -50%) scale(0.3);
    opacity: 0;
    animation: tap-ai 15s ease-in-out infinite;
  }
  @keyframes tap-ai {
    0%, 31% { opacity: 0; transform: translate(-50%, -50%) scale(0.3); }
    35% { opacity: 0.5; transform: translate(-50%, -50%) scale(0.7); }
    39% { opacity: 0; transform: translate(-50%, -50%) scale(1.9); }
    100% { opacity: 0; }
  }

  /* green agent status pill, fades in right after the AI button is tapped and
     holds while the host drafts (then clears as the loop restarts) */
  .status-pill { opacity: 0; transform: translateY(4px); animation: status-in 15s ease-in-out infinite; }
  .status-dot { animation: status-pulse 1.1s ease-in-out infinite; }
  @keyframes status-in {
    0%, 34% { opacity: 0; transform: translateY(4px); }
    37%, 90% { opacity: 1; transform: translateY(0); }
    94%, 100% { opacity: 0; transform: translateY(4px); }
  }
  @keyframes status-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ---- the App's signature cyan reply buttons (from aiReplyStyles) ---- */
  .fast-reply-btn,
  .ai-reply-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex: 1;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 600;
    cursor: default;
    position: relative;
    overflow: hidden;
  }
  .fast-reply-btn {
    border: 1px solid rgba(6, 182, 212, 0.3);
    color: #0e7490;
    background: linear-gradient(135deg, #ecfeff, #cffafe);
  }
  .fast-sparkle { color: #06b6d4; }
  .ai-reply-btn {
    flex: 1.2;
    border: none;
    color: #fff;
    background: linear-gradient(135deg, #0891b2, #06b6d4, #22d3ee);
    box-shadow: 0 2px 12px rgba(6, 182, 212, 0.4);
  }
  .ai-reply-btn::before,
  .fast-reply-btn::before {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.25) 50%, transparent 100%);
    animation: ai-shimmer 2.8s ease-in-out infinite;
  }
  @keyframes ai-shimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* reduced motion: hold the static curated list, no pointer/transitions */
  @media (prefers-reduced-motion: reduce) {
    .screen-list { animation: none; opacity: 1; transform: none; }
    .screen-reader { display: none; }
    .pointer-cursor,
    .tap-ripple,
    .row-target,
    .status-pill,
    .status-dot,
    .ai-ripple,
    .ai-reply-btn::before,
    .fast-reply-btn::before { animation: none; }
    .status-pill { opacity: 0; }
  }
</style>
