---
/*
 * VS Code Copilot Chat shell - Dark Modern surfaces (#181818 chrome, #1f1f1f
 * editor, #313131 input), an activity bar with the active item on a #0078D4 rail,
 * the "CHAT" view header, a user turn with avatar, a Copilot assistant turn, an
 * Agent-mode tool-call row, and the bottom composer with Agent/model pickers and
 * a blue send button. Theme hex from microsoft/vscode dark_modern.json. Card stays cyan.
 */
import ConvoScroll from "./ConvoScroll.astro";

const navIcon = "size-5 text-[#858585]";
---

<div class="flex overflow-hidden rounded-lg border border-[#2b2b2b] bg-[#1f1f1f] text-[#cccccc] shadow-2xl shadow-black/50">
  <!-- activity bar -->
  <div class="flex w-11 shrink-0 flex-col items-center gap-4 border-r border-[#2b2b2b] bg-[#181818] py-3">
    <!-- active: chat (blue left rail) -->
    <span class="relative flex w-full justify-center">
      <span class="absolute left-0 top-1/2 h-5 w-0.5 -translate-y-1/2 bg-[#0078d4]"></span>
      <svg class="size-5 text-[#ffffff]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.38 8.38 0 0 1 4 11.5 8.5 8.5 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5z" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </span>
    <svg class={navIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 4h7l2 2h9v13H3z" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    <svg class={navIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-4.3-4.3" stroke-linecap="round"></path></svg>
    <svg class={navIcon} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="6" cy="6" r="2.5"></circle><circle cx="6" cy="18" r="2.5"></circle><circle cx="18" cy="9" r="2.5"></circle><path d="M8.5 6H14a3 3 0 0 1 3 3M6 8.5v7" stroke-linecap="round"></path></svg>
    <svg class={`${navIcon} mt-auto`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><circle cx="12" cy="8" r="3.5"></circle><path d="M5 20a7 7 0 0 1 14 0" stroke-linecap="round"></path></svg>
  </div>

  <!-- chat panel -->
  <div class="min-w-0 flex-1 bg-[#181818]">
    <!-- panel header -->
    <div class="flex items-center justify-between border-b border-[#2b2b2b] px-3 py-2">
      <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.15em] text-[#858585]">Chat</span>
      <span class="flex items-center gap-2.5 text-[#858585]">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke-linecap="round"></path></svg>
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"></circle><path d="M12 7v5l3 2" stroke-linecap="round"></path></svg>
        <span class="text-base leading-none">⋯</span>
      </span>
    </div>

    <div class="space-y-3 px-3 py-3">
      <!-- user turn -->
      <div class="flex gap-2.5">
        <span class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-[#3c3c3c] font-mono text-[10px] text-[#cccccc]">U</span>
        <p class="min-w-0 flex-1 text-[13px] text-[#cccccc]">Triage my inbox and draft replies.</p>
      </div>

      <!-- Copilot turn -->
      <div class="flex gap-2.5">
        <svg class="mt-0.5 size-5 shrink-0 text-[#cccccc]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3zM5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16z"></path></svg>
        <div class="min-w-0 flex-1 space-y-2">
          <p class="text-[13px] leading-relaxed text-[#cccccc]">Triaged your inbox in agent mode:</p>
          <!-- agent tool-call row -->
          <div class="flex items-center gap-1.5 rounded border border-[#2b2b2b] bg-[#1f1f1f] px-2 py-1 text-[11px] text-[#9d9d9d]">
            <svg class="size-3 text-[#858585]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 8l4 4-4 4m6 0h6"></path></svg>
            <span class="flex-1 truncate font-mono">Ran <span class="text-[#4daafc]">gmail_curate_inbox</span></span>
            <svg class="size-3.5 rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </div>
          <ConvoScroll>
            <!-- summoned host-chat turn: the app posted this user message -->
            <div class="flex gap-2.5">
              <span class="mt-0.5 grid size-5 shrink-0 place-items-center rounded-full bg-[#3c3c3c] font-mono text-[10px] text-[#cccccc]">U</span>
              <p class="min-w-0 flex-1 text-[13px] text-[#cccccc]">Draft a researched reply to the Q3 contract thread from Dana.</p>
            </div>
            <!-- Copilot continues: agent tool-call row + result -->
            <div class="flex gap-2.5">
              <svg class="mt-0.5 size-5 shrink-0 text-[#cccccc]" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 3l1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3zM5 16l.9 2.1L8 19l-2.1.9L5 22l-.9-2.1L2 19l2.1-.9L5 16z"></path></svg>
              <div class="min-w-0 flex-1 space-y-2">
                <div class="flex items-center gap-1.5 rounded border border-[#2b2b2b] bg-[#1f1f1f] px-2 py-1 text-[11px] text-[#9d9d9d]">
                  <svg class="size-3 text-[#858585]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 8l4 4-4 4m6 0h6"></path></svg>
                  <span class="flex-1 truncate font-mono">Ran <span class="text-[#4daafc]">gmail_reply_to_thread</span></span>
                  <svg class="size-3.5 rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                </div>
                <p class="text-[13px] leading-relaxed text-[#cccccc]">Researched the thread and drafted a reply, saved to your inbox.</p>
              </div>
            </div>
          </ConvoScroll>
        </div>
      </div>
    </div>

    <!-- composer -->
    <div class="px-3 pb-3">
      <div class="rounded-md border border-[#0078d4] bg-[#313131] p-2">
        <p class="px-1 pt-0.5 text-[13px] text-[#8a8a8a]">Ask Copilot</p>
        <div class="mt-2 flex items-center gap-2">
          <span class="inline-flex items-center gap-1 rounded border border-[#3c3c3c] px-1.5 py-0.5 text-[11px] text-[#cccccc]">
            Agent
            <svg class="size-3 text-[#858585]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </span>
          <span class="inline-flex items-center gap-1 text-[11px] text-[#9d9d9d]">
            Auto
            <svg class="size-3 text-[#858585]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </span>
          <span class="ml-auto grid size-6 place-items-center rounded bg-[#0078d4] text-white">
            <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M2 21l21-9L2 3v7l15 2-15 2z"></path></svg>
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
