---
import { testimonials } from "../config/landing";
---

{
  testimonials.enabled && (
    <section class="border-t border-border/60 py-24">
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">
          {testimonials.heading}
        </h2>
        <div class="mt-14 grid gap-6 md:grid-cols-2">
          {testimonials.items.map((t) => (
            <figure class="border-2 border-border bg-surface-1 p-8 transition hover:border-accent/50">
              <blockquote class="text-pretty text-lg leading-relaxed text-fg">
                “{t.quote}”
              </blockquote>
              <figcaption class="mt-6 flex items-center gap-3">
                {t.avatar ? (
                  <img
                    src={t.avatar}
                    alt=""
                    width="40"
                    height="40"
                    loading="lazy"
                    class="size-10 shrink-0 border border-accent/50 object-cover grayscale"
                  />
                ) : (
                  <span class="grid size-10 shrink-0 place-items-center border border-accent/50 font-semibold text-accent">
                    {t.name.charAt(0)}
                  </span>
                )}
                <span>
                  <span class="block font-medium">{t.name}</span>
                  <span class="block text-sm text-fg-muted">{t.title}</span>
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )
}
