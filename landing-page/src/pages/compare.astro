---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import ComparisonTable from "../components/ComparisonTable.astro";
import PillarCards from "../components/PillarCards.astro";
import { site, comparison } from "../config/landing";

const origin = (Astro.site ?? new URL(site.url)).origin;

const pageTitle = `Compare GmailMCP - alternatives & 'vs' breakdowns`;
const pageDescription = comparison.subhead;

// schema.org: a comparison WebPage that lists the competitors we cover, plus a
// breadcrumb. Advertised via /schemamap.xml so answer engines pick it up.
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: pageTitle,
    description: pageDescription,
    url: `${origin}/compare`,
    isPartOf: { "@type": "WebSite", name: site.name, url: site.url },
    about: comparison.competitors.map((c) => ({ "@type": "Thing", name: c.name })),
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "GmailMCP comparisons",
    itemListElement: comparison.competitors.map((c, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: `GmailMCP vs ${c.name}`,
      url: `${origin}/vs/${c.id}`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site.url },
      { "@type": "ListItem", position: 2, name: "Compare", item: `${origin}/compare` },
    ],
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <script
    type="application/ld+json"
    is:inline
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />

  <Nav />
  <main class="mx-auto max-w-6xl px-6 py-16">
    <a href="/" class="text-sm opacity-70 hover:opacity-100">&larr; Back to {site.name}</a>

    <header class="mt-6 max-w-3xl">
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        {comparison.heading}
      </h1>
      <p class="mt-4 text-lg text-fg-muted">{comparison.subhead}</p>
    </header>

    <!-- The three pillars -->
    <section class="mt-14">
      <PillarCards as="h2" />
    </section>

    <!-- Full matrix -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">At a glance</h2>
      <div class="mt-6">
        <ComparisonTable competitors={comparison.competitors} />
      </div>
    </section>

    <!-- Per-competitor cards -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold tracking-tight">Head-to-head</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-2">
        {
          comparison.competitors.map((c) => (
            <a
              href={`/vs/${c.id}`}
              class="group flex flex-col border-2 border-border bg-surface-1 p-6 transition hover:border-accent"
            >
              <span class="font-mono text-xs uppercase tracking-widest text-fg-subtle">
                {c.category}
              </span>
              <h3 class="mt-2 text-xl font-semibold">
                GmailMCP vs {c.name}
              </h3>
              <p class="mt-3 grow text-pretty leading-relaxed text-fg-muted">
                {c.headline}
              </p>
              <span class="mt-4 inline-flex items-center gap-2 font-medium text-accent">
                Read the comparison
                <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <div class="mt-16 border-t border-border/60 pt-10 text-center">
      <a
        href="/#how-it-works"
        class="inline-flex items-center gap-2 bg-accent px-5 py-2.5 font-semibold text-accent-fg transition hover:bg-accent-strong"
      >
        Add GmailMCP to your client
      </a>
    </div>
  </main>
  <Footer />
</Base>
