---
import Base from "../layouts/Base.astro";
import { site } from "../config/landing";

const operator = "GPU-EVM LTD";
const operatorAddress = "3rd Floor, 86-90 Paul Street, London, England, EC2A 4NE";
const supportEmail = "support@daysurface.com";
const jurisdiction = "England and Wales";
const effectiveDate = "June 20, 2026";
---

<Base
  title={`Terms of Service - ${site.name}`}
  description={`The terms governing your use of ${site.name}.`}
>
  <main class="mx-auto max-w-3xl px-6 py-16 leading-relaxed">
    <a href="/" class="text-sm opacity-70 hover:opacity-100">&larr; Back to {site.name}</a>
    <h1 class="mt-6 text-4xl font-bold">Terms of Service</h1>
    <p class="mt-2 text-sm opacity-70">Effective {effectiveDate}</p>

    <p class="mt-8">
      These Terms govern your use of {site.name} ("the Service"), operated by
      {operator} ("we", "us"). By connecting an account or otherwise using the
      Service, you agree to these Terms. If you do not agree, do not use the
      Service.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">The Service</h2>
    <p class="mt-3">
      {site.name} is a Model Context Protocol server that connects an AI client
      you control to your Gmail account so that client can read, organize,
      draft, and send email at your direction. You are responsible for the AI
      client you connect and for the actions you instruct it to take.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Your account and authorization</h2>
    <ul class="mt-3 list-disc space-y-2 pl-6">
      <li>
        You must own, or be authorized to use, the Google account you connect,
        and you must comply with Google's terms in doing so.
      </li>
      <li>
        You grant the Service permission to perform Gmail actions on your behalf
        only as needed to carry out the requests you make through your connected
        AI client.
      </li>
      <li>
        You are responsible for keeping your credentials and connected clients
        secure.
      </li>
    </ul>

    <h2 class="mt-10 text-2xl font-semibold">Acceptable use</h2>
    <p class="mt-3">You agree not to use the Service to:</p>
    <ul class="mt-3 list-disc space-y-2 pl-6">
      <li>send spam, phishing, or other unlawful or deceptive email;</li>
      <li>violate the rights of others or any applicable law;</li>
      <li>
        attempt to gain unauthorized access to the Service, other accounts, or
        its underlying systems; or
      </li>
      <li>interfere with or disrupt the integrity or performance of the Service.</li>
    </ul>

    <h2 class="mt-10 text-2xl font-semibold">Privacy</h2>
    <p class="mt-3">
      Your use of the Service is also governed by our
      <a href="/privacy" class="underline">Privacy Policy</a>, which describes
      how we handle Google user data, including under the Google API Services
      User Data Policy Limited Use requirements.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Disclaimer of warranties</h2>
    <p class="mt-3">
      The Service is provided "as is" and "as available" without warranties of
      any kind, whether express or implied, including fitness for a particular
      purpose and non-infringement. We do not warrant that the Service will be
      uninterrupted, error-free, or that any email action will succeed.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Limitation of liability</h2>
    <p class="mt-3">
      To the maximum extent permitted by law, {operator} will not be liable for
      any indirect, incidental, special, consequential, or punitive damages, or
      any loss of data, email, or profits, arising out of or relating to your
      use of the Service.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Termination</h2>
    <p class="mt-3">
      You may stop using the Service and revoke its access at any time. We may
      suspend or terminate access that violates these Terms or that we
      reasonably believe poses a security or legal risk.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Governing law</h2>
    <p class="mt-3">
      These Terms are governed by the laws of {jurisdiction}, without regard to
      conflict-of-laws rules.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Changes</h2>
    <p class="mt-3">
      We may update these Terms; material changes will be reflected by a new
      effective date above. Continued use after changes take effect constitutes
      acceptance.
    </p>

    <h2 class="mt-10 text-2xl font-semibold">Contact</h2>
    <p class="mt-3">
      <a class="underline" href={`mailto:${supportEmail}`}>{supportEmail}</a>
    </p>
    <p class="mt-3">
      {operator}, a company registered in England and Wales, {operatorAddress}.
    </p>

    <p class="mt-12">
      <a href="/privacy" class="underline">Privacy Policy</a>
    </p>
  </main>
</Base>
