# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROK_API_KEY=xai-...
GROQ_API_KEY=gsk_...
PERPLEXITY_API_KEY=pplx-...
GEMINI_API_KEY=AIza...
CEREBRAS_API_KEY=csk-...

# Environment
DEV_ENV=dev

# Telegram
TELEGRAM_BOT_TOKEN=

# Database
SUPABASE_PASSWORD=
BACKEND_DB_URI=postgresql://user:pass@host:port/db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# LangFuse
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_PRICE_ID=
STRIPE_TEST_WEBHOOK_SECRET=

# WorkOS
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# OAuth 2.1 for the MCP transport: AuthKit issuer URL + the public /mcp URL
# (must match the resource indicator configured in the WorkOS dashboard)
WORKOS_AUTHKIT_DOMAIN=
MCP_PUBLIC_URL=

# Web Bot Auth (HTTP Message Signatures key directory)
# base64url-encoded 32-byte Ed25519 private key seed; published as a public JWK
# Set at /.well-known/http-message-signatures-directory. Generate with:
#   python -c "import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).rstrip(b'=').decode())"
WEB_BOT_AUTH_PRIVATE_KEY=

# Session
SESSION_SECRET_KEY=

# GitHub
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=                          # OAuth client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=                      # OAuth client secret from Google Cloud Console
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=
GOOGLE_TOKEN_ENC_KEY=                      # Fernet key (url-safe base64, 32 bytes) for refresh-token encryption

# Testing
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_USER_ID=
